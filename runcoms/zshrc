# ---- Completion matching: case-insensitive substring (match anywhere) ----
# fzf-tab can only fuzzy-filter candidates that zsh's completion system emits,
# and zsh defaults to prefix-only matching (so `cd ./schedul<TAB>` misses the
# mid-string `vertex-scheduling-*` dirs).
#
# This is intentionally a SINGLE matcher entry, not a progressive list. A list
# like `'' 'm:...' 'l:|=* r:|=*'` is tried in order and STOPS at the first entry
# that yields any match -- so as soon as a prefix matched (schedule-app-poc,
# scheduling) zsh never reached the substring matcher and dropped the rest.
# Combining case-insensitive (`m:{a-zA-Z}={A-Za-z}`) with match-anywhere
# (`l:|=* r:|=*`) in one entry makes substring matching always apply, so
# `schedul` returns schedule-app-poc, scheduling, vertex-scheduling-api and
# vertex-scheduling-poc together. (cd is aliased to zoxide's `z`, whose path
# completion delegates to zsh `_files`, which honors this matcher-list.)
zstyle ':completion:*' matcher-list 'm:{a-zA-Z}={A-Za-z} l:|=* r:|=*'

# ---- fzf-tab (fzf-powered <TAB> completion menu) ----
# Replaces zsh's default completion menu with an fzf picker for ALL commands
# (cd, git, kill, export, ssh, ...). MUST be sourced after compinit and BEFORE
# widget-wrapping plugins (zsh-autosuggestions / zsh-syntax-highlighting below).
if [[ -s "${HOME}/.fzf-tab/fzf-tab.plugin.zsh" ]]; then
    echo "FZF TAB!"
    # fzf-tab needs the default menu disabled to take over selection.
    zstyle ':completion:*' menu no
    # Reuse the FZF_DEFAULT_OPTS theme/keybinds defined in the FZF section.
    zstyle ':fzf-tab:*' use-fzf-default-opts yes
    # Jump between completion groups with < and >.
    zstyle ':fzf-tab:*' switch-group '<' '>'
    # Directory preview for cd / zoxide using eza, mirroring FZF_ALT_C_OPTS.
    zstyle ':fzf-tab:complete:(cd|z):*' fzf-preview \
        'eza --tree --color=always --icons=always "${realpath}" | head -200'

    source "${HOME}/.fzf-tab/fzf-tab.plugin.zsh"
fi

