function _change-profile() {
    account_id="${1}"
    region="${2}"
    role="${3}"
    environment="${4}"
    cluster_name="${environment}-vertex-platform"
    cluster_arn="arn:aws:eks:${region}:${account_id}:cluster/${cluster_name}"
    
    export AWS_PROFILE="${role}-${account_id}"
    export AWS_REGION="${region}"

    if ! aws sts get-caller-identity --profile "${AWS_PROFILE}" > /dev/null 2>&1; then
        aws sso login --profile "${AWS_PROFILE}"
        if ! aws sts get-caller-identity --profile "${AWS_PROFILE}" > /dev/null 2>&1; then
            echo "Failed to login to AWS"
            return 1
        fi
    fi

    if ! kubectl config get-contexts -o name 2>/dev/null | grep -qx "${cluster_arn}"; then
        aws eks update-kubeconfig --region us-east-1 --name "${cluster_name}" > /dev/null
    fi

    kubectl config use-context "${cluster_arn}" > /dev/null
}

function unset-profile() {
    unset AWS_PROFILE
    unset AWS_REGION
    kubectl config unset current-context > /dev/null
}

